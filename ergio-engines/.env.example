"""
ERGIO Engines — Environment Configuration
Copy this to .env and fill in your keys
"""

# ── Server ──
PORT=8000
HOST=0.0.0.0
# CORS — comma-separated list. Use * to allow ERGIO frontend
CORS_ORIGINS=https://ergio.vercel.app,http://localhost:3000,http://localhost:5173

# ── Groq AI (free tier — get key at https://console.groq.com/keys) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_SMART=llama-3.3-70b-versatile

# ── Supabase (same as ERGIO frontend) ──
SUPABASE_URL=https://owcxfzlanlrulflsyvlr.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# ── Scraping ──
# SearXNG instance URL (use a public one or self-host)
SEARXNG_URL=https://search.sapti.me
# Playwright browser config
HEADLESS=true
BROWSER_TIMEOUT=30000
MAX_CONCURRENT_CRAWLS=5
MAX_PAGES_PER_CRAWL=20

# ── Lead Generation ──
MAX_LEADS_PER_SCAN=25
LEAD_SCORE_THRESHOLD=40
# Nigerian cities to focus on
DEFAULT_CITIES=Lagos,Abuja,Port Harcourt,Kano,Ibadan

# ── Scheduler ──
# How often to run each engine (in minutes)
ENGINE_DISCOVERY_INTERVAL_HOURS=6
ENGINE_MATCHING_INTERVAL_MINUTES=30
ENGINE_OUTREACH_INTERVAL_HOURS=2
ENGINE_REPEAT_INTERVAL_HOURS=12

# ── Email Outreach (Resend — free tier) ──
RESEND_API_KEY=your_resend_key
FROM_EMAIL=hello@ergio.app

# ── Logging ──
LOG_LEVEL=INFO
