{
  "functions": {
    "api/[[...route]].js": {
      "maxDuration": 120
    },
    "api/setup.js": {
      "maxDuration": 30
    },
    "api/generate.js": {
      "maxDuration": 120
    }
  },
  "buildCommand": "echo 'build ok'",
  "rewrites": [
    {
      "source": "/api/setup",
      "destination": "/api/setup"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/[[...route]]"
    }
  ]
}
