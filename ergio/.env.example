# ERGIO Environment Variables
# Copy this to .env and fill in your values
# These go in Vercel Project Settings > Environment Variables

# Supabase (from your Supabase project dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Groq AI (from console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Paystack (from dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key

# Resend (from resend.com - optional, for email outreach)
RESEND_API_KEY=re_your-resend-key
