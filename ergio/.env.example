# ERGIO Environment Variables for Vercel
# Copy these to Vercel > Settings > Environment Variables

# === SUPABASE ===
SUPABASE_URL=https://xxfbvjhebwxdkkjynnkz.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# === GROQ AI (Free Tier) ===
GROQ_API_KEY=your_groq_api_key_here

# === PAYSTACK ===
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

# === RESEND (Email - Free 3000/month) ===
RESEND_API_KEY=your_resend_api_key_here

# === WHATSAPP BUSINESS API (Free 1000 conversations/month) ===
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here

# === JAN AI (Optional - Local LLM) ===
JAN_API_URL=http://localhost:1337/v1
JAN_DEFAULT_MODEL=llama-3.1-8b-instruct

# === OPEN-SOURCE ENGINES (No keys needed) ===
# Pollinations.ai - Free image/text generation (no key)
# OSM Nominatim - Free geocoding (no key)
# SearXNG - Free meta search (no key)
# Overpass API - Free OSM queries (no key)
# Cheerio - Built-in scraper (no key)
